---
export type AIUsage = 'human' | 'ai-assisted' | 'ai-coauthored' | 'ai-generated';

interface Props {
	aiUsage?: AIUsage;
}

const { aiUsage = 'human' } = Astro.props;

const labels: Record<AIUsage, string> = {
	'human': 'Human Written',
	'ai-assisted': 'AI Assisted',
	'ai-coauthored': 'AI Co-authored',
	'ai-generated': 'AI Generated',
};

const descriptions: Record<AIUsage, string> = {
	'human': 'This post was written entirely by the author without AI assistance.',
	'ai-assisted': 'This post was drafted by the author; AI was used for editing and refinement.',
	'ai-coauthored': 'This post was substantially co-written with AI tools.',
	'ai-generated': 'This post was largely generated by AI and edited by the author.',
};

const icons: Record<AIUsage, string> = {
	'human': '✍️',
	'ai-assisted': '🤝',
	'ai-coauthored': '⚙️',
	'ai-generated': '🤖',
};

const colorClasses: Record<AIUsage, string> = {
	'human': 'bg-green-100 text-green-800 border-green-300',
	'ai-assisted': 'bg-yellow-100 text-yellow-800 border-yellow-300',
	'ai-coauthored': 'bg-orange-100 text-orange-800 border-orange-300',
	'ai-generated': 'bg-red-100 text-red-800 border-red-300',
};

const label = labels[aiUsage];
const description = descriptions[aiUsage];
const icon = icons[aiUsage];
const colorClass = colorClasses[aiUsage];
---

<span
	class={`ai-usage-badge inline-flex items-center gap-1 px-2 py-1 text-xs font-medium border rounded-full ${colorClass}`}
	title={description}
	aria-label={description}
>
	<span aria-hidden="true">{icon}</span>
	{label}
</span>
