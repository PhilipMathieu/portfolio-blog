---
export type AIUsage = 'human' | 'co-authored' | 'generative';

interface Props {
	aiUsage?: AIUsage;
}

const { aiUsage = 'human' } = Astro.props;

const labels: Record<AIUsage, string> = {
	'human': 'Human-authored',
	'co-authored': 'AI Co-authored',
	'generative': 'Generative',
};

const descriptions: Record<AIUsage, string> = {
	'human': 'Written by the author, with minimal AI use (e.g. proofreading or workshopping).',
	'co-authored': 'Substantial portions written by AI with close human involvement and editing.',
	'generative': 'Most content written by AI with minimal human involvement (e.g. fact-checking).',
};

const icons: Record<AIUsage, string> = {
	'human': '✍️',
	'co-authored': '🤝',
	'generative': '🤖',
};

const colorClasses: Record<AIUsage, string> = {
	'human': 'bg-green-100 text-green-800 border-green-300',
	'co-authored': 'bg-yellow-100 text-yellow-800 border-yellow-300',
	'generative': 'bg-orange-100 text-orange-800 border-orange-300',
};

const label = labels[aiUsage];
const description = descriptions[aiUsage];
const icon = icons[aiUsage];
const colorClass = colorClasses[aiUsage];
---

<span
	class={`ai-usage-badge inline-flex items-center gap-1 px-2 py-1 text-xs font-medium border rounded-full ${colorClass}`}
	title={description}
	aria-label={description}
>
	<span aria-hidden="true">{icon}</span>
	{label}
</span>
